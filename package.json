    "allure-playwright": "^3.7.1",
    "cross-env": "^10.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "chalk": "^5.6.2",
